# PUBG Developer API Key
# Get your key at: https://developer.pubg.com/
PUBG_API_KEY=your_pubg_api_key_here

# Rate Limiter (true | false, default: true)
PUBG_RATE_LIMIT=true

# Response Cache (true | false, default: true)
PUBG_CACHE=true

# Cache TTL in milliseconds (default: 60000 = 1 minute)
PUBG_CACHE_TTL=60000

# HTTP Request timeout in milliseconds (default: 10000 = 10 seconds)
PUBG_TIMEOUT=10000

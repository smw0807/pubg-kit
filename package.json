{
  "name": "pubg-kit",
  "version": "1.4.2",
  "description": "PUBG REST API TypeScript SDK + NestJS Module",
  "author": "",
  "license": "MIT",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./nestjs": {
      "types": "./dist/nestjs.d.ts",
      "import": "./dist/nestjs.js",
      "require": "./dist/nestjs.cjs"
    }
  },
  "typesVersions": {
    "*": {
      "nestjs": [
        "./dist/nestjs.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "lru-cache": "^11.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/common": "^10.3.10",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.3.10",
    "@types/node": "^20.14.9",
    "@vitest/coverage-v8": "^2.0.3",
    "msw": "^2.3.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tsup": "^8.1.0",
    "typescript": "^5.5.3",
    "vitest": "^2.0.3"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "@nestjs/core": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/smw0807/pubg-kit.git"
  },
  "homepage": "https://github.com/smw0807/pubg-kit#readme",
  "bugs": {
    "url": "https://github.com/smw0807/pubg-kit/issues"
  },
  "keywords": [
    "pubg",
    "battlegrounds",
    "api",
    "sdk",
    "nestjs",
    "typescript"
  ]
}

{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "pubg-kit": ["../src/index.ts"],
      "pubg-kit/nestjs": ["../src/nestjs/index.ts"]
    }
  },
  "include": ["src/**/*", "../src/**/*"],
  "exclude": ["node_modules", "dist"]
}
